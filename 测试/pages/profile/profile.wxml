<!--pages/profile/profile.wxml-->
<view class="profile-page">
  <navigation-bar title="个人中心" back="{{true}}" color="black" background="#FFF"></navigation-bar>
  
  <scroll-view class="scroll-area" scroll-y>
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <view class="avatar-container">
        <view class="avatar">
          <text class="avatar-icon">👤</text>
        </view>
      </view>
      <view class="user-info">
        <text class="user-name">我的日记</text>
        <text class="user-desc">记录 {{diaryCount}} 篇心情故事</text>
      </view>
    </view>

    <!-- 本地存储证明 -->
    <view class="storage-proof">
      <view class="proof-header">
        <text class="proof-icon">💾</text>
        <text class="proof-title">数据存储</text>
      </view>
      <view class="proof-content">
        <view class="proof-item">
          <view class="proof-icon-small">📱</view>
          <view class="proof-text">
            <text class="proof-label">存储位置</text>
            <text class="proof-value">仅本地设备</text>
          </view>
        </view>
        <view class="proof-item">
          <view class="proof-icon-small">🔐</view>
          <view class="proof-text">
            <text class="proof-label">访问权限</text>
            <text class="proof-value">仅您本人</text>
          </view>
        </view>
        <view class="proof-item">
          <view class="proof-icon-small">🚫</view>
          <view class="proof-text">
            <text class="proof-label">云端访问</text>
            <text class="proof-value">{{cloudSync ? '已开启' : '未开启'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 隐私说明 -->
    <view class="privacy-section">
      <view class="privacy-card">
        <text class="privacy-icon">🔒</text>
        <view class="privacy-content">
          <text class="privacy-title">隐私保护</text>
          <text class="privacy-desc">
            您的日记仅保存在本设备本地存储中，微光日记无法访问您的数据。我们不会收集、存储或查看您的任何日记内容。
          </text>
        </view>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-section">
      <view class="menu-item" bindtap="goToReport">
        <view class="menu-left">
          <text class="menu-icon">📊</text>
          <text class="menu-text">情绪周报</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToSettings">
        <view class="menu-left">
          <text class="menu-icon">⚙️</text>
          <text class="menu-text">设置</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToDiaryList">
        <view class="menu-left">
          <text class="menu-icon">📖</text>
          <text class="menu-text">我的日记</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="showPrivacyInfo">
        <view class="menu-left">
          <text class="menu-icon">ℹ️</text>
          <text class="menu-text">关于隐私</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- 版本信息 -->
    <view class="version-info">
      <text class="version-text">微光日记 v1.0.0</text>
      <text class="version-text">温柔陪伴，不定义你</text>
    </view>
  </scroll-view>
</view>