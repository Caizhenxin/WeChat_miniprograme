/* pages/profile/profile.wxss */
page {
  height: 100vh;
  background-color: #FDF8F2;
}
.scroll-area {
  flex: 1;
  overflow-y: auto;
  padding: 0 30rpx 40rpx;
  box-sizing: border-box;
}
.user-card {
  background: linear-gradient(135deg, #D4B595 0%, #C49A76 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin: 30rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(180, 150, 120, 0.3);
}
.avatar-container { flex-shrink: 0; }
.avatar {
  width: 100rpx;
  height: 100rpx;
  background-color: rgba(255,255,255,0.3);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-icon { font-size: 50rpx; }
.user-info { flex: 1; }
.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: white;
  display: block;
  margin-bottom: 8rpx;
}
.user-desc { font-size: 26rpx; color: rgba(255,255,255,0.85); }

.storage-proof {
  background-color: #FFFCF7;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(180,150,120,0.1);
  border: 1rpx solid #EADBC6;
}
.proof-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 24rpx; }
.proof-icon { font-size: 32rpx; }
.proof-title { font-size: 28rpx; font-weight: 600; color: #2B3A42; }
.proof-content { display: flex; flex-direction: column; gap: 20rpx; }
.proof-item {
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 20rpx; background-color: #FDF8F2;
  border-radius: 12rpx;
}
.proof-icon-small { font-size: 28rpx; }
.proof-text { flex: 1; display: flex; justify-content: space-between; align-items: center; }
.proof-label { font-size: 26rpx; color: #8B7E74; }
.proof-value {
  font-size: 26rpx; font-weight: 500; color: #8B5E3C;
  background-color: #FDF0E4; padding: 4rpx 16rpx; border-radius: 8rpx;
}

.privacy-section { margin-bottom: 24rpx; }
.privacy-card {
  background-color: #FFFCF7; border-radius: 20rpx; padding: 30rpx;
  display: flex; gap: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(180,150,120,0.1);
  border: 1rpx solid #EADBC6;
  border-left: 8rpx solid #C49A76;
}
.privacy-icon { font-size: 36rpx; flex-shrink: 0; }
.privacy-content { flex: 1; }
.privacy-title { font-size: 28rpx; font-weight: 600; color: #2B3A42; display: block; margin-bottom: 12rpx; }
.privacy-desc { font-size: 26rpx; color: #8B7E74; line-height: 1.6; display: block; }

.menu-section {
  background-color: #FFFCF7; border-radius: 20rpx; overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(180,150,120,0.1);
  border: 1rpx solid #EADBC6;
}
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 28rpx 30rpx; border-bottom: 1rpx solid #EADBC6; }
.menu-item:last-child { border-bottom: none; }
.menu-left { display: flex; align-items: center; gap: 16rpx; }
.menu-icon { font-size: 32rpx; }
.menu-text { font-size: 28rpx; color: #2B3A42; }
.menu-arrow { font-size: 36rpx; color: #B5A99B; }

.version-info { text-align: center; padding: 30rpx 0; }
.version-text { font-size: 24rpx; color: #B5A99B; display: block; margin-bottom: 8rpx; }
