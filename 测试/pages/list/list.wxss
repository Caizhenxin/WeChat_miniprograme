/* pages/list/list.wxss */
page {
	height: 100vh;
	background: #FDF8F2;
}
.list-page { height: 100vh; }
.scroll-area {
	height: calc(100vh - 88rpx);
	padding: 24rpx;
	box-sizing: border-box;
}
.privacy-card {
	background: #FFFCF7;
	border-radius: 16rpx;
	padding: 20rpx;
	margin-bottom: 20rpx;
	border: 1rpx solid #EADBC6;
}
.privacy-title {
	display: block; font-size: 28rpx; font-weight: 600;
	color: #2B3A42; margin-bottom: 8rpx;
}
.privacy-text {
	display: block; font-size: 24rpx; color: #8B7E74; line-height: 1.6;
}
.diary-item {
	background: #FFFCF7;
	border-radius: 14rpx;
	padding: 18rpx;
	margin-bottom: 12rpx;
	display: flex;
	align-items: flex-start;
	justify-content: space-between;
	border: 1rpx solid #EADBC6;
}
.diary-main { flex: 1; margin-right: 12rpx; }
.diary-time {
	display: block; font-size: 23rpx; color: #B5A99B; margin-bottom: 8rpx;
}
.diary-preview {
	display: block; font-size: 26rpx; color: #2B3A42; line-height: 1.5; margin-bottom: 10rpx;
}
.feedback-row { display: flex; flex-wrap: wrap; align-items: center; gap: 8rpx; }
.feedback-chip {
	font-size: 22rpx; color: #8B5E3C; background: #FDF0E4;
	border-radius: 999rpx; padding: 4rpx 12rpx;
}
.feedback-action { font-size: 22rpx; color: #8B7E74; }
.feedback-empty { font-size: 22rpx; color: #B5A99B; }
.item-actions { display: flex; flex-direction: column; gap: 8rpx; }
.delete-btn { color: #C44; background: #FFF0F0; }
.feedback-btn { color: #8B5E3C; background: #FDF0E4; }

.empty-state { text-align: center; padding: 100rpx 0; }
.empty-icon { display: block; font-size: 84rpx; margin-bottom: 10rpx; }
.empty-title { display: block; font-size: 30rpx; color: #2B3A42; margin-bottom: 8rpx; font-weight: 600; }
.empty-desc { font-size: 24rpx; color: #B5A99B; }
