/* pages/diary/diary.wxss */

/* 容器 */
.diary-container {
  padding: 30rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
}

/* 输入框 */
.diary-textarea {
  width: 100%;
  height: 300rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
  margin-bottom: 30rpx;
  font-size: 28rpx;
}

/* 主要按钮 */
.diary-primary-btn {
  background-color: #7c3aed;
  margin-bottom: 40rpx;
  color: #fff;
  border-radius: 16rpx;
}

/* 雷达图区域 */
.radar-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.radar-chart {
  width: 100%;
  height: 400rpx;
}

/* 咨询流派回应区域 */
.counseling-section {
  background: linear-gradient(135deg, #667eea10 0%, #764ba210 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-left: 8rpx solid #667eea;
}

.counseling-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.counseling-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.counseling-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #667eea;
}

.counseling-response {
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
}

/* 流派列表 */
.schools-list {
  margin-top: 20rpx;
}

.school-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.school-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
  margin-bottom: 12rpx;
}

.school-response {
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.5;
}

/* 微行动卡片 */
.action-card {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-top: 30rpx;
}

.action-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #92400e;
  display: block;
  margin-bottom: 20rpx;
}

.action-steps {
  font-size: 28rpx;
  color: #b45309;
  line-height: 1.6;
  display: block;
  white-space: pre-line;
  margin-bottom: 24rpx;
}

.action-card-btn {
  background-color: #f59e0b;
  color: #fff;
  border-radius: 40rpx;
}

/* 分析结果区域 */
.analysis-result {
  margin: 24rpx 0;
  padding: 24rpx;
  background-color: #f0f7ff;
  border-radius: 16rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.result-item {
  margin: 12rpx 0;
  font-size: 28rpx;
}

.result-label {
  color: #666;
  font-weight: 500;
}
.radar-canvas {
  width: 600rpx;
  height: 600rpx;
  margin: 0 auto;
  display: block;
}
.radar-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.radar-chart {
  width: 300px;
  height: 300px;
  margin: 0 auto;
}
.result-value {
  color: #07C160;
  margin-left: 16rpx;
}