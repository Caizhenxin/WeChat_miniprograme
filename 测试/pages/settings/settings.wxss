/* pages/settings/settings.wxss */
.settings-page {
  padding: 32rpx;
  background: #FDF8F2;
  min-height: 100vh;
}
.setting-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 0; border-bottom: 1rpx solid #EADBC6;
}
.setting-info { flex: 1; margin-right: 24rpx; }
.title { font-size: 32rpx; font-weight: 500; color: #2B3A42; display: block; margin-bottom: 8rpx; }
.desc { font-size: 24rpx; color: #8B7E74; }
.privacy-note {
  margin-top: 48rpx; padding: 24rpx;
  background-color: #FFFCF7; border-radius: 16rpx;
  display: flex; align-items: center;
  border: 1rpx solid #EADBC6;
}
.note-icon { font-size: 32rpx; margin-right: 16rpx; }
.note-text { font-size: 26rpx; color: #5C4F42; flex: 1; }
