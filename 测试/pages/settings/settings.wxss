/* pages/settings/settings.wxss */
.settings-page {
  padding: 32rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eee;
}

.setting-info {
  flex: 1;
  margin-right: 24rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.desc {
  font-size: 24rpx;
  color: #999;
}

.privacy-note {
  margin-top: 48rpx;
  padding: 24rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
}

.note-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.note-text {
  font-size: 26rpx;
  color: #666;
  flex: 1;
}