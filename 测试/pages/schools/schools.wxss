/**pages/schools/schools.wxss - 温暖纸质风格**/
page {
  height: 100vh;
  background: #FDF8F2;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.schools-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.scroll-area {
  flex: 1;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

.progress-card {
  background: linear-gradient(135deg, #D4B595 0%, #C49A76 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}
.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.progress-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}
.progress-percent {
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
}
.progress-bar {
  background: rgba(255,255,255,0.3);
  border-radius: 10rpx;
  height: 12rpx;
  overflow: hidden;
}
.progress-fill {
  background: #fff;
  border-radius: 10rpx;
  height: 100%;
  transition: width 0.3s ease;
}
.progress-tip {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 12rpx;
  display: block;
}

.intro-card {
  background: linear-gradient(135deg, #FFFCF7 0%, #FDF8F2 100%);
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid #EADBC6;
}
.intro-title {
  display: block;
  font-size: 30rpx;
  color: #2B3A42;
  font-weight: 700;
  margin-bottom: 10rpx;
}
.intro-desc {
  display: block;
  font-size: 25rpx;
  color: #5C4F42;
  line-height: 1.7;
}

.school-card {
  background: #FFFCF7;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 14rpx;
  position: relative;
  border: 1rpx solid #EADBC6;
  transition: all 0.3s ease;
}
.school-card.expanded {
  box-shadow: 0 4rpx 20rpx rgba(180, 150, 120, 0.2);
  border-color: #D4B595;
}

.school-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.school-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #2B3A42;
}
.school-tag {
  font-size: 22rpx;
  color: #8B5E3C;
  background: #FDF0E4;
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
}
.school-desc {
  display: block;
  font-size: 25rpx;
  color: #5C4F42;
  line-height: 1.6;
  margin-bottom: 8rpx;
}
.school-highlight, .school-suitable {
  display: block;
  font-size: 24rpx;
  color: #8B7E74;
  line-height: 1.6;
}

.school-detail {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #EADBC6;
}
.detail-title {
  font-size: 26rpx;
  color: #C49A76;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}
.detail-list { margin-bottom: 16rpx; }
.detail-item {
  font-size: 24rpx;
  color: #5C4F42;
  line-height: 1.8;
  display: block;
}
.mark-btn {
  background: linear-gradient(135deg, #D4B595 0%, #C49A76 100%);
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 30rpx;
  border-radius: 20rpx;
  border: none;
  display: inline-block;
}

.expand-icon {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  font-size: 22rpx;
  color: #B5A99B;
}

.enter-btn {
  margin-top: 24rpx;
  margin-bottom: 30rpx;
  background: linear-gradient(135deg, #D4B595 0%, #C49A76 100%);
  color: #fff;
  border-radius: 999rpx;
  font-size: 28rpx;
}
